# Copia este archivo a .env y rellena los valores.
# El .env NUNCA se sube al repo (está en .gitignore).

# Clave de la API de Anthropic — sacar en https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Dominio final del sitio (sin slash al final)
SITE_URL=https://automatizacionslatam.com

# ID de cliente de Google AdSense (formato ca-pub-XXXXXXXXXXXXXXXX)
PUBLIC_ADSENSE_CLIENT=ca-pub-0000000000000000

# ID de Google Analytics 4 (formato G-XXXXXXXXXX) — opcional pero recomendado.
# OJO: este es el ID de MEDICIÓN del snippet del sitio, distinto del PROPERTY_ID
# numérico que usa la Data API (ver GA4_PROPERTY_ID abajo).
PUBLIC_GA_ID=G-XXXXXXXXXX

# --- Datos reales para el "cerebro" (analytics.py) — saca al orquestador del ---
# --- modo degradado. Todos server-side (NO llevan prefijo PUBLIC_).           ---
# --- Se crean con una service account de Google. Ver guía en MONETIZACION o    ---
# --- MARKETING; el mismo trío va como secrets de GitHub en el repo.            ---

# Contenido COMPLETO del JSON de la clave de la service account (una sola línea
# o multilínea entre comillas). La service account debe tener acceso de LECTURA
# a la propiedad de Search Console y a la propiedad de GA4.
GOOGLE_SERVICE_ACCOUNT_JSON=

# Property ID NUMÉRICO de GA4 (ej. 123456789) — Admin → Configuración de la
# propiedad. NO es el G-XXXXXXXXXX.
GA4_PROPERTY_ID=

# URL de la propiedad en Search Console. Para propiedad de dominio usa el
# formato sc-domain:automatizacionslatam.com ; para prefijo de URL, la URL http(s).
GSC_SITE_URL=https://automatizacionslatam.com
