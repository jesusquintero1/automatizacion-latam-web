---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CookieBanner from '../components/CookieBanner.astro';

interface Props {
  title: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
}

const {
  title,
  description = 'Noticias diarias de automatización industrial, robótica e Industria 4.0 para Latinoamérica. Resúmenes en español de las fuentes más importantes del sector.',
  canonical,
  ogImage,
} = Astro.props;

const siteUrl = import.meta.env.SITE ?? Astro.site?.toString() ?? 'https://automatizacionslatam.com';
const canonicalUrl = canonical ?? new URL(Astro.url.pathname, siteUrl).toString();

const ADSENSE = import.meta.env.PUBLIC_ADSENSE_CLIENT;
const GA_ID = import.meta.env.PUBLIC_GA_ID;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalUrl} />

    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <!-- Fuentes -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Source+Serif+Pro:wght@600;700&display=swap"
      rel="stylesheet"
    />

    <!-- RSS propio (ayuda a SEO y suscripciones) -->
    <link rel="alternate" type="application/rss+xml" title="Automatización LatAm" href="/rss.xml" />

    {ADSENSE && <meta name="google-adsense-account" content={ADSENSE} />}
    {ADSENSE && (
      <>
        <script is:inline>
          {`
            window.adsbygoogle = window.adsbygoogle || [];
            if (!localStorage.getItem('cookie-consent')) {
              window.adsbygoogle.pauseAdRequests = 1;
            } else if (localStorage.getItem('cookie-consent') === 'rejected') {
              window.adsbygoogle.requestNonPersonalizedAds = 1;
            }
          `}
        </script>
        <script
          async
          src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${ADSENSE}`}
          crossorigin="anonymous"
        ></script>
      </>
    )}

    {ogImage && <meta property="og:image" content={ogImage.startsWith('http') ? ogImage : new URL(ogImage, siteUrl).toString()} />}
    {ogImage && <meta name="twitter:image" content={ogImage.startsWith('http') ? ogImage : new URL(ogImage, siteUrl).toString()} />}
    {!ogImage && <meta property="og:image" content={new URL('/og-default.png', siteUrl).toString()} />}
    {!ogImage && <meta name="twitter:image" content={new URL('/og-default.png', siteUrl).toString()} />}
    <meta property="og:site_name" content="Automatización LatAm" />
    <meta property="og:locale" content="es_LA" />

    {GA_ID && (
      <>
        <script async src={`https://www.googletagmanager.com/gtag/js?id=${GA_ID}`}></script>
        <script is:inline define:vars={{ GA_ID }}>
          window.dataLayer = window.dataLayer || [];
          function gtag() { dataLayer.push(arguments); }
          gtag('js', new Date());
          gtag('config', GA_ID);
        </script>
      </>
    )}
  </head>
  <body class="bg-white text-ink-900 font-sans antialiased">
    <Header />
    <main class="min-h-[70vh]">
      <slot />
    </main>
    <Footer />
    <CookieBanner />
  </body>
</html>
