---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CookieBanner from '../components/CookieBanner.astro';

interface Props {
  title: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  // articulo: true en paginas de noticia individual (cambia og:type y modifica robots).
  articulo?: boolean;
  // noIndex: true en paginas que no deben indexarse (p.ej. 404). Emite
  // noindex,nofollow (corta todo).
  noIndex?: boolean;
  // noIndexFollow: true en paginas podadas por baja calidad (noticias thin/viejas).
  // Emite noindex,FOLLOW: Google las saca del indice pero sigue rastreando sus
  // enlaces internos hacia las guias/pillars, que es lo que queremos conservar.
  noIndexFollow?: boolean;
  // Fecha de publicacion / modificacion (solo articulos).
  publishedTime?: string;
  modifiedTime?: string;
  // Tags / categoria para og:article.
  ogSection?: string;
  ogTags?: string[];
}

const {
  title,
  description = 'Noticias diarias de automatización industrial, robótica e Industria 4.0 para Latinoamérica. Resúmenes en español de las fuentes más importantes del sector.',
  canonical,
  ogImage,
  articulo = false,
  noIndex = false,
  noIndexFollow = false,
  publishedTime,
  modifiedTime,
  ogSection,
  ogTags,
} = Astro.props;

const siteUrl = import.meta.env.SITE ?? Astro.site?.toString() ?? 'https://automatizacionslatam.com';
const cleanSiteUrl = siteUrl.replace(/\/$/, '');
const canonicalUrl = canonical ?? new URL(Astro.url.pathname, siteUrl).toString();
const isHome = Astro.url.pathname === '/' || Astro.url.pathname === '';

const ADSENSE = import.meta.env.PUBLIC_ADSENSE_CLIENT;
const GA_ID = import.meta.env.PUBLIC_GA_ID;
const GOOGLE_VERIFY = import.meta.env.PUBLIC_GOOGLE_SITE_VERIFICATION;
const BING_VERIFY = import.meta.env.PUBLIC_BING_VERIFICATION;
const YANDEX_VERIFY = import.meta.env.PUBLIC_YANDEX_VERIFICATION;

// JSON-LD Organization + WebSite (global). Refuerzan E-E-A-T para Google.
const jsonLdOrganization = {
  '@context': 'https://schema.org',
  '@type': 'NewsMediaOrganization',
  name: 'Automatización LatAm',
  alternateName: 'AutomatizacionLatAm',
  url: cleanSiteUrl,
  logo: {
    '@type': 'ImageObject',
    url: `${cleanSiteUrl}/og-default.png`,
    width: 1200,
    height: 630,
  },
  description: 'Noticias y análisis diario sobre automatización industrial, PLC, robótica, IA y ciberseguridad OT para profesionales en Latinoamérica.',
  inLanguage: 'es',
  foundingDate: '2026-05',
  knowsAbout: [
    'Automatización industrial',
    'PLC',
    'SCADA',
    'Robótica industrial',
    'Industria 4.0',
    'Inteligencia Artificial',
    'Ciberseguridad OT',
    'IIoT',
    'Gemelos digitales',
  ],
  sameAs: [
    'https://www.linkedin.com/company/automatizacion-latam',
    'https://twitter.com/automatizalatam',
  ],
  contactPoint: {
    '@type': 'ContactPoint',
    contactType: 'editorial',
    email: 'contacto@automatizacionslatam.com',
    availableLanguage: ['Spanish', 'English'],
  },
  publishingPrinciples: `${cleanSiteUrl}/sobre/`,
  ethicsPolicy: `${cleanSiteUrl}/sobre/`,
};

const jsonLdWebsite = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Automatización LatAm',
  url: cleanSiteUrl,
  inLanguage: 'es',
  potentialAction: {
    '@type': 'SearchAction',
    target: `${cleanSiteUrl}/?q={search_term_string}`,
    'query-input': 'required name=search_term_string',
  },
};
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalUrl} />

    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:type" content={articulo ? 'article' : 'website'} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    {articulo && publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {articulo && modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}
    {articulo && ogSection && <meta property="article:section" content={ogSection} />}
    {articulo && ogTags && ogTags.map((t) => <meta property="article:tag" content={t} />)}
    {articulo && <meta property="article:publisher" content={cleanSiteUrl} />}

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@automatizalatam" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <!-- SEO: robots, theme-color, autor del sitio, color de UI movil -->
    <meta name="robots" content={noIndex ? 'noindex,nofollow' : noIndexFollow ? 'noindex,follow' : 'index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1'} />
    <meta name="googlebot" content={noIndex ? 'noindex,nofollow' : noIndexFollow ? 'noindex,follow' : 'index,follow,max-image-preview:large,max-snippet:-1'} />
    <meta name="author" content="Automatización LatAm" />
    <meta name="publisher" content="Automatización LatAm" />
    <meta name="theme-color" content="#0f4a8a" />
    <meta name="color-scheme" content="light" />
    <meta name="format-detection" content="telephone=no" />
    <meta http-equiv="content-language" content="es" />
    <link rel="alternate" hreflang="es" href={canonicalUrl} />
    <link rel="alternate" hreflang="x-default" href={canonicalUrl} />

    <!-- Fuentes -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Source+Serif+Pro:wght@600;700&display=swap"
      rel="stylesheet"
    />

    <!-- RSS propio (ayuda a SEO y suscripciones) -->
    <link rel="alternate" type="application/rss+xml" title="Automatización LatAm" href="/rss.xml" />

    <!-- Verificación de propiedad en Search Engines (se inyectan si los env vars están) -->
    {GOOGLE_VERIFY && <meta name="google-site-verification" content={GOOGLE_VERIFY} />}
    {BING_VERIFY && <meta name="msvalidate.01" content={BING_VERIFY} />}
    {YANDEX_VERIFY && <meta name="yandex-verification" content={YANDEX_VERIFY} />}

    {ADSENSE && <meta name="google-adsense-account" content={ADSENSE} />}
    {ADSENSE && (
      <>
        <script is:inline>
          {`
            window.adsbygoogle = window.adsbygoogle || [];
            if (!localStorage.getItem('cookie-consent')) {
              window.adsbygoogle.pauseAdRequests = 1;
            } else if (localStorage.getItem('cookie-consent') === 'rejected') {
              window.adsbygoogle.requestNonPersonalizedAds = 1;
            }
          `}
        </script>
        <script
          async
          src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${ADSENSE}`}
          crossorigin="anonymous"
        ></script>
      </>
    )}

    {ogImage && <meta property="og:image" content={ogImage.startsWith('http') ? ogImage : new URL(ogImage, siteUrl).toString()} />}
    {ogImage && <meta name="twitter:image" content={ogImage.startsWith('http') ? ogImage : new URL(ogImage, siteUrl).toString()} />}
    {!ogImage && <meta property="og:image" content={new URL('/og-default.png', siteUrl).toString()} />}
    {!ogImage && <meta name="twitter:image" content={new URL('/og-default.png', siteUrl).toString()} />}
    <meta property="og:site_name" content="Automatización LatAm" />
    <meta property="og:locale" content="es_LA" />

    <!-- JSON-LD: Organization + WebSite (global, en todas las páginas) -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLdOrganization)} />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebsite)} />

    {GA_ID && (
      <>
        <script async src={`https://www.googletagmanager.com/gtag/js?id=${GA_ID}`}></script>
        <script is:inline define:vars={{ GA_ID }}>
          window.dataLayer = window.dataLayer || [];
          function gtag() { dataLayer.push(arguments); }
          gtag('js', new Date());
          gtag('config', GA_ID);
        </script>
      </>
    )}
    <!-- Slot opcional para que cada pagina pueda inyectar tags al head:
         preload de imagen LCP, JSON-LD especificos, etc. -->
    <slot name="head" />
  </head>
  <body class="bg-white text-ink-900 font-sans antialiased">
    <Header />
    <main class="min-h-[70vh]">
      <slot />
    </main>
    <Footer />
    <CookieBanner />
  </body>
</html>
