---
interface Props {
  slot: string;
  format?: string;
  layout?: 'in-article' | 'auto' | 'fluid';
  label?: string;
}
const { slot, format = 'auto', layout = 'auto', label = 'Publicidad' } = Astro.props;
const client = import.meta.env.PUBLIC_ADSENSE_CLIENT;
---
{client ? (
  <aside class="my-8 text-center">
    <div class="text-[10px] uppercase tracking-wider text-ink-300 mb-1">{label}</div>
    <ins
      class="adsbygoogle block"
      style="display:block"
      data-ad-client={client}
      data-ad-slot={slot}
      data-ad-format={format}
      data-ad-layout={layout === 'auto' ? undefined : layout}
      data-full-width-responsive="true"
    ></ins>
    <script is:inline>
      (adsbygoogle = window.adsbygoogle || []).push({});
    </script>
  </aside>
) : (
  <aside class="my-8 border-2 border-dashed border-ink-300/40 rounded-lg p-6 text-center text-sm text-ink-300">
    Espacio AdSense ({slot}) — configura <code>PUBLIC_ADSENSE_CLIENT</code> en <code>.env</code>
  </aside>
)}
