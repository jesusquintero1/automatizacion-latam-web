---
import type { CollectionEntry } from 'astro:content';

interface Props {
  noticia: CollectionEntry<'noticias'>;
  variant?: 'default' | 'compact' | 'featured';
}
const { noticia, variant = 'default' } = Astro.props;
const { titulo, resumen, categoria, fuente, fecha, imagen } = noticia.data;
const href = `/noticia/${noticia.slug}/`;
const fechaStr = new Date(fecha).toLocaleDateString('es', { day: 'numeric', month: 'short', year: 'numeric' });
---
{variant === 'featured' ? (
  <article class="md:col-span-2 group">
    <a href={href} class="block">
      {imagen && (
        <div class="aspect-[16/9] overflow-hidden rounded-xl mb-4 bg-ink-300/20">
          <img src={imagen} alt={titulo} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
        </div>
      )}
      <div class="flex items-center gap-2 text-xs text-brand-600 font-semibold uppercase tracking-wide mb-2">
        <span>{categoria}</span>
        <span class="text-ink-300">·</span>
        <span class="text-ink-500">{fechaStr}</span>
      </div>
      <h2 class="text-2xl md:text-3xl font-serif font-bold text-ink-900 group-hover:text-brand-600 transition-colors mb-2 leading-tight">
        {titulo}
      </h2>
      <p class="text-ink-700 text-lg leading-relaxed line-clamp-3">{resumen}</p>
      <p class="text-xs text-ink-500 mt-3">Fuente: {fuente.nombre}</p>
    </a>
  </article>
) : (
  <article class="group border-b border-ink-300/20 pb-6 last:border-0">
    <a href={href} class="block">
      <div class="flex items-center gap-2 text-xs text-brand-600 font-semibold uppercase tracking-wide mb-2">
        <span>{categoria}</span>
        <span class="text-ink-300">·</span>
        <span class="text-ink-500">{fechaStr}</span>
      </div>
      <h3 class="text-xl font-serif font-bold text-ink-900 group-hover:text-brand-600 transition-colors mb-2 leading-snug">
        {titulo}
      </h3>
      <p class="text-ink-700 leading-relaxed line-clamp-2">{resumen}</p>
      <p class="text-xs text-ink-500 mt-2">Fuente: {fuente.nombre}</p>
    </a>
  </article>
)}
