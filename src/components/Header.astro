---
// El logo lleva al home asi que omitimos "Inicio" en nav — usamos ese slot
// para "Sobre" que AdSense y Google valoran como senal E-E-A-T.
const navItems = [
  { href: '/categoria/inteligencia-artificial/', label: 'IA' },
  { href: '/categoria/plc-y-control/', label: 'PLC y Control' },
  { href: '/categoria/robotica/', label: 'Robótica' },
  { href: '/categoria/industria-4-0/', label: 'Industria 4.0' },
  { href: '/categoria/ciberseguridad-ot/', label: 'Ciberseguridad OT' },
  { href: '/sobre/', label: 'Sobre' },
];

// Páginas-guía (pillars evergreen). Se listan en un menú "Guías" para darles
// enlaces internos desde el Header y concentrar autoridad temática.
// Trailing slash obligatorio (trailingSlash: 'always') para evitar 301 y no
// desperdiciar presupuesto de rastreo.
const guiaItems = [
  { href: '/guias/', label: '★ Todas las guías' },
  { href: '/glosario/', label: '★ Glosario técnico' },
  { href: '/herramientas/', label: '★ Herramientas gratis' },
  { href: '/guias/que-es-un-plc/', label: '¿Qué es un PLC?' },
  { href: '/guias/que-es-un-hmi/', label: '¿Qué es un HMI?' },
  { href: '/guias/que-es-scada/', label: '¿Qué es SCADA?' },
  { href: '/guias/que-es-un-cobot/', label: '¿Qué es un cobot?' },
  { href: '/guias/que-es-la-industria-4-0/', label: '¿Qué es la Industria 4.0?' },
  { href: '/guias/aprender-automatizacion-industrial/', label: 'Cómo aprender automatización' },
  { href: '/guias/temporizador-ton-tof-ladder/', label: 'Temporizadores en LADDER' },
  { href: '/guias/semaforo-zeliosoft-ladder/', label: 'Semáforo en ZelioSoft 2' },
  { href: '/guias/control-nivel-tanque-ladder/', label: 'Control de nivel de tanque' },
  { href: '/guias/entradas-analogicas-zelio-sr3-b261bd/', label: 'Entradas analógicas Zelio' },
  { href: '/guias/grafcet-ladder-set-reset/', label: 'Grafcet en LADDER' },
  { href: '/tema/plc-y-control/', label: 'PLC y control industrial' },
  { href: '/tema/inteligencia-artificial/', label: 'IA en la industria' },
  { href: '/tema/robotica/', label: 'Robótica industrial' },
  { href: '/tema/industria-4-0/', label: 'Industria 4.0 e IIoT' },
  { href: '/tema/ciberseguridad-ot/', label: 'Ciberseguridad OT' },
];
---
<header class="border-b border-ink-300/30 bg-white sticky top-0 z-40 backdrop-blur-md bg-white/90">
  <div class="mx-auto max-w-[var(--container)] px-4 md:px-8 flex items-center justify-between h-16">
    <a href="/" class="flex items-center gap-2 font-bold text-xl text-ink-900">
      <span class="inline-block w-8 h-8 rounded-md bg-gradient-to-br from-brand-500 to-brand-700"></span>
      <span>Automatización<span class="text-brand-600">LatAm</span></span>
    </a>
    <nav class="hidden md:flex items-center gap-6 text-sm font-medium text-ink-700">
      {navItems.map(({ href, label }) => (
        <a href={href} class="hover:text-brand-600 transition-colors">{label}</a>
      ))}
      <details class="guias-menu relative">
        <summary class="list-none cursor-pointer hover:text-brand-600 transition-colors flex items-center gap-1">
          Guías
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
        </summary>
        <div class="absolute right-0 mt-2 w-64 bg-white border border-ink-300/30 rounded-lg shadow-lg py-2 z-50">
          {guiaItems.map(({ href, label }) => (
            <a href={href} class="block px-4 py-2 text-ink-700 hover:bg-brand-50 hover:text-brand-600">{label}</a>
          ))}
        </div>
      </details>
    </nav>
    <button id="mobile-menu-toggle" class="md:hidden p-2" aria-label="Abrir menú">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>
      </svg>
    </button>
  </div>
  <nav id="mobile-menu" class="md:hidden hidden border-t border-ink-300/30 px-4 py-3 space-y-2 text-sm">
    {navItems.map(({ href, label }) => (
      <a href={href} class="block py-1 text-ink-700 hover:text-brand-600">{label}</a>
    ))}
    <p class="pt-2 mt-2 border-t border-ink-300/20 text-[11px] uppercase tracking-wider text-ink-500">Guías</p>
    {guiaItems.map(({ href, label }) => (
      <a href={href} class="block py-1 text-ink-700 hover:text-brand-600">{label}</a>
    ))}
  </nav>
</header>
<style>
  /* Cierra el menú "Guías" al hacer clic fuera es gestionado por <details>;
     ocultamos el marcador por defecto del summary. */
  .guias-menu > summary::-webkit-details-marker { display: none; }
</style>
<script>
  const btn = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));

  // Cerrar el dropdown "Guías" al hacer clic fuera.
  document.addEventListener('click', (e) => {
    document.querySelectorAll('details.guias-menu[open]').forEach((d) => {
      if (!d.contains(e.target as Node)) d.removeAttribute('open');
    });
  });
</script>
