---
// Herramienta gratuita: calculadora de escalado analógico (raw counts ↔ unidades
// de ingeniería). Linkbait técnico: alta intención entre técnicos de PLC, casi sin
// competencia en español. Isla de JS 100% cliente (compatible con output:static,
// sin dependencias externas → respeta la CSP). Incluye snippet de <iframe> para
// que otros la incrusten: cada incrustación externa es un backlink automático.
import Base from '../../layouts/Base.astro';
import AdSlot from '../../components/AdSlot.astro';

const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? 'https://automatizacionslatam.com';
const pageUrl = `${siteUrl}/herramientas/escalado-analogico/`;
const title = 'Calculadora de escalado analógico para PLC (raw ↔ unidades de ingeniería)';
const description = 'Convierte cuentas crudas (raw) de una entrada analógica de PLC a unidades de ingeniería y viceversa. Presets Siemens (0-27648), 12/15 bits y 4-20 mA. Gratis, sin registro.';

const jsonLdApp = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Calculadora de escalado analógico para PLC',
  applicationCategory: 'EngineeringApplication',
  operatingSystem: 'Web',
  description,
  url: pageUrl,
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  publisher: { '@type': 'Organization', name: 'Automatización LatAm', url: siteUrl },
};
const jsonLdBreadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Inicio', item: `${siteUrl}/` },
    { '@type': 'ListItem', position: 2, name: 'Herramientas', item: `${siteUrl}/herramientas/` },
    { '@type': 'ListItem', position: 3, name: 'Escalado analógico', item: pageUrl },
  ],
};
const embedCode = `<iframe src="${pageUrl}?embed=1" width="100%" height="520" style="border:1px solid #ddd;border-radius:8px" title="Calculadora de escalado analógico"></iframe>`;
---
<Base title={`${title} | Automatización LatAm`} description={description}>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdBreadcrumb)} />

  <article class="mx-auto max-w-3xl px-4 md:px-8 py-10 prose-article">
    <nav aria-label="Breadcrumb" class="text-xs text-ink-500 mb-3 not-prose" data-hide-embed>
      <a href="/" class="hover:text-brand-600">Inicio</a>
      <span class="mx-1">›</span>
      <span class="text-ink-700">Herramientas</span>
    </nav>
    <p class="text-brand-600 font-semibold uppercase tracking-wider text-sm mb-2 not-prose" data-hide-embed>Herramienta gratuita</p>
    <h1 class="text-3xl md:text-5xl font-serif font-bold text-ink-900 mb-4" data-hide-embed>Calculadora de escalado analógico</h1>

    <!-- CALCULADORA (isla JS) -->
    <div class="not-prose rounded-xl border border-ink-300/40 p-5 md:p-6 bg-white shadow-sm" id="esc-tool">
      <div class="mb-4">
        <label class="block text-sm font-semibold text-ink-700 mb-1" for="preset">Preset de señal cruda (raw)</label>
        <select id="preset" class="w-full px-3 py-2 rounded-md border border-ink-300/50 bg-white text-ink-900">
          <option value="0,27648">Siemens S7 (0 – 27648)</option>
          <option value="6400,32000">Siemens 4-20 mA (6400 – 32000)</option>
          <option value="0,4095">12 bits (0 – 4095)</option>
          <option value="0,32767">15 bits (0 – 32767)</option>
          <option value="0,65535">16 bits (0 – 65535)</option>
          <option value="custom">Personalizado…</option>
        </select>
      </div>

      <div class="grid grid-cols-2 gap-4 mb-4">
        <div>
          <label class="block text-xs font-semibold text-ink-500 mb-1" for="rawMin">Raw mín</label>
          <input id="rawMin" type="number" value="0" class="w-full px-3 py-2 rounded-md border border-ink-300/50" />
        </div>
        <div>
          <label class="block text-xs font-semibold text-ink-500 mb-1" for="rawMax">Raw máx</label>
          <input id="rawMax" type="number" value="27648" class="w-full px-3 py-2 rounded-md border border-ink-300/50" />
        </div>
        <div>
          <label class="block text-xs font-semibold text-ink-500 mb-1" for="euMin">Ingeniería mín</label>
          <input id="euMin" type="number" value="0" class="w-full px-3 py-2 rounded-md border border-ink-300/50" />
        </div>
        <div>
          <label class="block text-xs font-semibold text-ink-500 mb-1" for="euMax">Ingeniería máx</label>
          <input id="euMax" type="number" value="100" class="w-full px-3 py-2 rounded-md border border-ink-300/50" />
        </div>
      </div>

      <div class="grid md:grid-cols-2 gap-4 border-t border-ink-300/30 pt-4">
        <div class="rounded-lg bg-brand-50 p-4">
          <label class="block text-sm font-semibold text-brand-700 mb-1" for="rawVal">Raw → Ingeniería</label>
          <input id="rawVal" type="number" value="13824" class="w-full px-3 py-2 rounded-md border border-brand-300 mb-2" />
          <p class="text-sm text-ink-700">Valor: <strong id="euOut" class="text-brand-700 text-lg">50</strong> <span id="euUnit"></span></p>
        </div>
        <div class="rounded-lg bg-ink-100 p-4">
          <label class="block text-sm font-semibold text-ink-700 mb-1" for="euVal">Ingeniería → Raw</label>
          <input id="euVal" type="number" value="75" class="w-full px-3 py-2 rounded-md border border-ink-300/50 mb-2" />
          <p class="text-sm text-ink-700">Raw: <strong id="rawOut" class="text-ink-900 text-lg">20736</strong></p>
        </div>
      </div>

      <p class="text-xs text-ink-500 mt-4 font-mono" id="formula"></p>
    </div>

    <div data-hide-embed>
      <p class="text-xl text-ink-700 leading-relaxed border-l-4 border-brand-500 pl-4 my-8 italic not-prose">
        Convierte el valor "crudo" que entrega una entrada analógica de PLC a la magnitud física real (bar, °C, %, l/min) y al revés. Escribe cualquier valor y el resultado se calcula al instante.
      </p>

      <h2>Qué es el escalado analógico</h2>
      <p>Cuando un sensor (de presión, temperatura, nivel o caudal) se conecta a una entrada analógica de un PLC, el conversor analógico-digital no entrega directamente la magnitud física, sino un número entero llamado <strong>valor crudo</strong> o <em>raw</em>. Por ejemplo, en un PLC Siemens S7 una señal de 0 a 10 V o de 0 a 20 mA se representa con un raw de <strong>0 a 27648</strong>. El escalado analógico es la operación que traduce ese número a la unidad de ingeniería que le importa al operador.</p>

      <h2>La fórmula</h2>
      <p>El escalado es una simple interpolación lineal entre dos rangos: el rango crudo (raw mín–máx) y el rango de ingeniería (EU mín–máx):</p>
      <p class="not-prose font-mono bg-ink-100 rounded-md p-4 text-sm">EU = EU_min + (raw − raw_min) × (EU_max − EU_min) / (raw_max − raw_min)</p>
      <p>Y para el sentido inverso (de unidad de ingeniería a raw), se despeja <code>raw</code>. Esta misma cuenta es la que hacen internamente instrucciones como <code>SCALE</code>/<code>NORM_X</code> y <code>SCALE_X</code> en TIA Portal, o los bloques de escalado de cualquier plataforma.</p>

      <AdSlot slot="9999999999" label="Publicidad" />

      <h2>Rangos crudos habituales</h2>
      <ul>
        <li><strong>Siemens S7 (0–27648):</strong> el rango nominal para 0–10 V o 0–20 mA. Para 4–20 mA el rango vivo va de 5530 a 27648, y por debajo indica rotura de hilo.</li>
        <li><strong>Siemens 4–20 mA (6400–32000):</strong> escala alternativa usada en algunas configuraciones/familias.</li>
        <li><strong>12 bits (0–4095):</strong> típico de muchos módulos y microcontroladores.</li>
        <li><strong>15 bits (0–32767) y 16 bits (0–65535):</strong> resoluciones altas de módulos de gama media y alta.</li>
      </ul>

      <h2>Ejemplo</h2>
      <p>Un transmisor de presión de 0 a 10 bar conectado a un S7. Si el PLC lee un raw de 13824 (justo la mitad de 27648), la presión real es 5 bar. Introduce esos valores arriba y compruébalo.</p>

      <div class="not-prose my-8 rounded-xl border border-ink-300/40 p-5 bg-ink-50">
        <h2 class="text-lg font-bold text-ink-900 mb-2">¿Tienes un blog o das clases? Incrusta esta calculadora</h2>
        <p class="text-sm text-ink-600 mb-3">Copia este código en tu web para embeber la herramienta gratis:</p>
        <textarea readonly rows="3" class="w-full text-xs font-mono p-3 rounded-md border border-ink-300/50 bg-white" onclick="this.select()">{embedCode}</textarea>
      </div>

      <p class="not-prose"><a href="/glosario/setpoint/" class="text-brand-600 font-semibold hover:underline">Ver glosario: setpoint, PID y control →</a></p>
    </div>
  </article>

  <script is:inline>
    (function () {
      const $ = (id) => document.getElementById(id);
      const els = ['rawMin', 'rawMax', 'euMin', 'euMax', 'rawVal', 'euVal'].map($);
      const [rawMin, rawMax, euMin, euMax, rawVal, euVal] = els;
      const preset = $('preset');

      function num(el, def) { const v = parseFloat(el.value); return isNaN(v) ? def : v; }

      function scaleRawToEu(raw, rMin, rMax, eMin, eMax) {
        if (rMax === rMin) return eMin;
        return eMin + ((raw - rMin) * (eMax - eMin)) / (rMax - rMin);
      }
      function scaleEuToRaw(eu, rMin, rMax, eMin, eMax) {
        if (eMax === eMin) return rMin;
        return rMin + ((eu - eMin) * (rMax - rMin)) / (eMax - eMin);
      }
      function round(x) { return Math.round(x * 1000) / 1000; }

      function recompute() {
        const rMin = num(rawMin, 0), rMax = num(rawMax, 27648);
        const eMin = num(euMin, 0), eMax = num(euMax, 100);
        $('euOut').textContent = round(scaleRawToEu(num(rawVal, 0), rMin, rMax, eMin, eMax));
        $('rawOut').textContent = Math.round(scaleEuToRaw(num(euVal, 0), rMin, rMax, eMin, eMax));
        $('formula').textContent =
          'EU = ' + eMin + ' + (raw − ' + rMin + ') × (' + eMax + ' − ' + eMin + ') / (' + rMax + ' − ' + rMin + ')';
      }

      preset.addEventListener('change', function () {
        if (preset.value === 'custom') return;
        const parts = preset.value.split(',');
        rawMin.value = parts[0];
        rawMax.value = parts[1];
        recompute();
      });
      els.forEach((el) => el.addEventListener('input', recompute));

      // Modo embed: ?embed=1 oculta cabecera/artículo y deja solo la calculadora.
      try {
        if (new URLSearchParams(location.search).get('embed') === '1') {
          document.querySelectorAll('[data-hide-embed]').forEach((n) => (n.style.display = 'none'));
        }
      } catch (e) {}

      recompute();
    })();
  </script>
</Base>
