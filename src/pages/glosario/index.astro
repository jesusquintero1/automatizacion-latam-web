---
// Índice del glosario técnico: hub que enlaza todos los términos y reparte
// PageRank interno hacia ellos. ItemList JSON-LD (sí elegible para rich result).
import Base from '../../layouts/Base.astro';
import { GLOSARIO } from '../../data/glosario';

const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? 'https://automatizacionslatam.com';
const pageUrl = `${siteUrl}/glosario/`;

const ordenados = [...GLOSARIO].sort((a, b) => a.termino.localeCompare(b.termino, 'es'));

const title = 'Glosario de automatización industrial: términos de PLC, SCADA, IIoT y más';
const description = 'Definiciones claras en español de los términos clave de la automatización industrial y la Industria 4.0: PLC, SCADA, HMI, DCS, IIoT, OPC UA, cobot, gemelo digital y más.';

const jsonLdList = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Glosario de automatización industrial',
  numberOfItems: ordenados.length,
  itemListElement: ordenados.map((t, idx) => ({
    '@type': 'ListItem',
    position: idx + 1,
    url: `${siteUrl}/glosario/${t.slug}/`,
    name: t.termino,
  })),
};
const jsonLdBreadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Inicio', item: `${siteUrl}/` },
    { '@type': 'ListItem', position: 2, name: 'Glosario', item: pageUrl },
  ],
};
---
<Base title={`${title} | Automatización LatAm`} description={description}>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdList)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdBreadcrumb)} />

  <section class="mx-auto max-w-4xl px-4 md:px-8 py-10">
    <nav aria-label="Breadcrumb" class="text-xs text-ink-500 mb-3">
      <a href="/" class="hover:text-brand-600">Inicio</a>
      <span class="mx-1">›</span>
      <span class="text-ink-700">Glosario</span>
    </nav>
    <p class="text-brand-600 font-semibold uppercase tracking-wider text-sm mb-2">Referencia</p>
    <h1 class="text-3xl md:text-5xl font-serif font-bold text-ink-900 mb-4">Glosario de automatización industrial</h1>
    <p class="text-ink-500 text-lg max-w-2xl mb-10">
      Definiciones claras, en español y sin rodeos, de los términos que todo técnico e ingeniero de automatización necesita dominar. {ordenados.length} conceptos y creciendo.
    </p>

    <ul class="grid sm:grid-cols-2 gap-4">
      {ordenados.map((t) => (
        <li>
          <a href={`/glosario/${t.slug}/`} class="block h-full rounded-lg border border-ink-300/30 p-5 hover:border-brand-500 transition-colors">
            <span class="font-semibold text-ink-900 text-lg">{t.termino}</span>
            <span class="block text-sm text-ink-500 mt-1">{t.resumen}</span>
          </a>
        </li>
      ))}
    </ul>
  </section>
</Base>
