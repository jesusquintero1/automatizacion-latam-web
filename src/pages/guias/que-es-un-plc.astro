const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? 'https://automatizacionslatam.com';
const pageUrl = `${siteUrl}/guias/que-es-un-plc/`;
const title = '¿Qué es un PLC? Guía completa: cómo funciona, tipos, lenguajes y cómo elegir uno';
const description = 'Qué es un PLC (controlador lógico programable), cómo funciona su ciclo de scan, los tipos y marcas (Siemens, Rockwell, Schneider), los lenguajes IEC 61131-3 y cómo elegir uno. Guía en español para Latinoamérica.';

const faq = [
  { q: '¿Qué es un PLC en palabras simples?', a: 'Un PLC (controlador lógico programable) es una computadora industrial robusta que lee señales de sensores, ejecuta una lógica programada y acciona salidas como motores y válvulas. Es el "cerebro" que automatiza máquinas y procesos en la industria.' },
  { q: '¿Para qué sirve un PLC?', a: 'Sirve para automatizar procesos: controlar una banda transportadora, dosificar líquidos, arrancar motores en secuencia, gestionar alarmas de seguridad, etc. Reemplaza cableados de relés por lógica programable, más flexible y fiable.' },
  { q: '¿Qué lenguaje usa un PLC?', a: 'La norma IEC 61131-3 define cinco lenguajes. El más usado es LADDER (diagrama de escalera), heredero de los relés; le siguen Texto Estructurado (ST), Bloques de Funciones (FBD), Lista de Instrucciones (IL) y Grafcet/SFC.' },
  { q: '¿Cuál es la diferencia entre un PLC y un microcontrolador (Arduino)?', a: 'Un microcontrolador como Arduino es barato y flexible para prototipos, pero un PLC está diseñado para la industria: soporta polvo, vibración y temperaturas extremas, tiene entradas/salidas robustas y aisladas, y una fiabilidad pensada para operar años sin fallar.' },
  { q: '¿Qué marca de PLC conviene aprender?', a: 'Siemens (TIA Portal) y Rockwell/Allen-Bradley dominan la industria pesada; Schneider, Omron y Delta son muy comunes en LatAm por costo. Lo importante es dominar los conceptos (IEC 61131-3, lazos de control): se transfieren entre marcas.' },
];

