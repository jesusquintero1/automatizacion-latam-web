---
// Guía evergreen de intención estudiante/docente: "semáforo en ZelioSoft 2
// LADDER ejercicio resuelto". SERP hoy = PDFs sueltos, Scribd y vídeos; ninguna
// página HTML dedicada y bien maquetada en español. Contenido 100% original
// (ejercicio resuelto con criterio de ingeniero), NO reescritura de feed.
import Base from '../../layouts/Base.astro';
import AdSlot from '../../components/AdSlot.astro';

const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? 'https://automatizacionslatam.com';
const pageUrl = `${siteUrl}/guias/semaforo-zeliosoft-ladder/`;
const title = 'Semáforo con LADDER en ZelioSoft 2: ejercicio resuelto paso a paso';
const description = 'Ejercicio resuelto de un semáforo en LADDER con ZelioSoft 2 (Zelio Logic): asignación de E/S, diagrama de escalera con tres temporizadores, lógica cíclica verde-amarillo-rojo y cómo simularlo.';

const faq = [
  { q: '¿Cuántos temporizadores necesito para un semáforo en LADDER?', a: 'Con tres temporizadores TON basta para un semáforo de una vía. Cada uno marca el fin de una fase (verde, amarillo, rojo) contando desde el inicio del ciclo con presets acumulados: 10 s, 13 s y 25 s en el ejemplo. Las salidas se deducen comparando en qué ventana de tiempo estás.' },
  { q: '¿Cómo hago que el ciclo del semáforo se repita solo?', a: 'Se usa una marca de "ciclo activo" (M1) que habilita los tres temporizadores. Cuando el último temporizador (fin de rojo) termina, su contacto abre la rama que sostiene M1 durante un scan: los temporizadores se ponen a cero y, como la marcha sigue presionada, M1 se vuelve a activar y el ciclo reinicia.' },
  { q: '¿Sirve el mismo programa para LOGO! Soft Comfort o TIA Portal?', a: 'Sí. La lógica es IEC 61131-3 estándar: cambian los nombres de los bloques y la representación gráfica, pero el concepto de tres retardos a la conexión (TON) acumulados y salidas por ventanas de tiempo es idéntico en LOGO!, TIA Portal, CODESYS o Zelio.' },
  { q: '¿Cómo simulo el semáforo en ZelioSoft 2?', a: 'En ZelioSoft 2 pulsa el botón de modo Simulación (S), fuerza la entrada de marcha I1 a 1 y observa cómo las salidas Q1, Q2 y Q3 se encienden en secuencia. El modo S ejecuta el programa en tiempo real dentro del PC sin necesidad del hardware Zelio.' },
  { q: '¿Qué módulo Zelio uso para este ejercicio?', a: 'Cualquier Zelio Logic con al menos una entrada digital y tres salidas sirve. En las soluciones de referencia usamos el SR3-B261BD (24 VDC, 10 entradas y 6 salidas de relé), que sobra para un semáforo y deja margen para ampliarlo a un cruce de dos vías.' },
];

const jsonLdArticle = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  inLanguage: 'es',
  mainEntityOfPage: pageUrl,
  author: { '@type': 'Organization', name: 'Automatización LatAm' },
  publisher: { '@type': 'Organization', name: 'Automatización LatAm', url: siteUrl },
};
const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faq.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })),
};
const jsonLdBreadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Inicio', item: `${siteUrl}/` },
    { '@type': 'ListItem', position: 2, name: 'Guías', item: `${siteUrl}/guias/` },
    { '@type': 'ListItem', position: 3, name: 'Semáforo en ZelioSoft 2', item: pageUrl },
  ],
};

const ladderCiclo = `  I1 (MARCHA)      T3 (fin rojo)                 M1 (CICLO)
 ----[ ]----+-------[/]-----------------------------( )----
            |
  M1 (CICLO)|
 ----[ ]----+

   M1 sostiene el ciclo; cuando T3 termina, su contacto NC
   abre la rama un scan → los temporizadores se reinician.`;

const ladderTimers = `  M1 (CICLO)                                    T1  PT=10s
 ----[ ]---------------------------------------[TON]--------
                                               (fin VERDE)

  M1 (CICLO)                                    T2  PT=13s
 ----[ ]---------------------------------------[TON]--------
                                               (fin AMARILLO)

  M1 (CICLO)                                    T3  PT=25s
 ----[ ]---------------------------------------[TON]--------
                                               (fin ROJO / reinicio)`;

const ladderSalidas = `  M1 (CICLO)       T1 (fin verde)               Q1 (VERDE)
 ----[ ]-----------[/]-------------------------------( )----   0–10 s

  T1 (fin verde)   T2 (fin amarillo)            Q2 (AMARILLO)
 ----[ ]-----------[/]-------------------------------( )----   10–13 s

  T2 (fin amarillo) T3 (fin rojo)               Q3 (ROJO)
 ----[ ]-----------[/]-------------------------------( )----   13–25 s`;
---
<Base title={`${title} | Automatización LatAm`} description={description}>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdArticle)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdBreadcrumb)} />

  <article class="mx-auto max-w-3xl px-4 md:px-8 py-10 prose-article">
    <nav aria-label="Breadcrumb" class="text-xs text-ink-500 mb-3 not-prose">
      <a href="/" class="hover:text-brand-600">Inicio</a>
      <span class="mx-1">›</span>
      <a href="/guias/" class="hover:text-brand-600">Guías</a>
      <span class="mx-1">›</span>
      <span class="text-ink-700">Semáforo en ZelioSoft 2</span>
    </nav>
    <p class="text-brand-600 font-semibold uppercase tracking-wider text-sm mb-2 not-prose">Ejercicio resuelto</p>
    <h1 class="text-3xl md:text-5xl font-serif font-bold text-ink-900 mb-6">Semáforo con LADDER en ZelioSoft 2, paso a paso</h1>

    <p class="text-xl text-ink-700 leading-relaxed border-l-4 border-brand-500 pl-4 mb-8 italic not-prose">
      El semáforo es el "hola mundo" de la automatización: un ciclo temporizado de tres estados que obliga a dominar temporizadores, marcas y secuencia. Aquí lo resolvemos completo en LADDER para ZelioSoft 2, con la asignación de entradas y salidas, el diagrama de escalera y cómo simularlo.
    </p>

    <p>Este ejercicio aparece en casi todos los cursos de <strong>Zelio Logic</strong> porque concentra los conceptos base: <strong>temporizadores</strong>, <strong>marcas internas</strong> y <strong>lógica secuencial cíclica</strong>. Lo resolveremos para un semáforo de una vía con tiempos <strong>verde 10 s, amarillo 3 s y rojo 12 s</strong> (ciclo total de 25 s), sobre un <strong>Zelio SR3-B261BD</strong>, pero el mismo programa vale para cualquier módulo con una entrada y tres salidas.</p>

    <h2>Paso 1 — Asignación de entradas y salidas (E/S)</h2>
    <p>Antes de tocar la escalera, define el mapa de E/S. Es el paso que más estudiantes se saltan y el que más errores evita:</p>
    <div class="not-prose overflow-x-auto my-6">
      <table class="w-full text-sm border-collapse">
        <thead>
          <tr class="border-b-2 border-ink-300">
            <th class="text-left py-2 pr-4">Elemento</th>
            <th class="text-left py-2 pr-4">Dirección</th>
            <th class="text-left py-2">Función</th>
          </tr>
        </thead>
        <tbody>
          <tr class="border-b border-ink-300/30"><td class="py-2 pr-4 font-semibold">Marcha</td><td class="py-2 pr-4">I1</td><td class="py-2">Pulsador/selector que arranca el ciclo</td></tr>
          <tr class="border-b border-ink-300/30"><td class="py-2 pr-4 font-semibold">Luz verde</td><td class="py-2 pr-4">Q1</td><td class="py-2">Salida de relé a la lámpara verde</td></tr>
          <tr class="border-b border-ink-300/30"><td class="py-2 pr-4 font-semibold">Luz amarilla</td><td class="py-2 pr-4">Q2</td><td class="py-2">Salida de relé a la lámpara amarilla</td></tr>
          <tr class="border-b border-ink-300/30"><td class="py-2 pr-4 font-semibold">Luz roja</td><td class="py-2 pr-4">Q3</td><td class="py-2">Salida de relé a la lámpara roja</td></tr>
          <tr class="border-b border-ink-300/30"><td class="py-2 pr-4 font-semibold">Ciclo activo</td><td class="py-2 pr-4">M1</td><td class="py-2">Marca interna que habilita los temporizadores</td></tr>
          <tr><td class="py-2 pr-4 font-semibold">Temporizadores</td><td class="py-2 pr-4">T1, T2, T3</td><td class="py-2">Fin de verde (10 s), amarillo (13 s) y rojo (25 s)</td></tr>
        </tbody>
      </table>
    </div>

    <AdSlot slot="7777777777" label="Publicidad" />

    <h2>Paso 2 — La idea clave: temporizadores acumulados</h2>
    <p>El truco pedagógico que hace este ejercicio simple es <strong>no</strong> reiniciar un temporizador por fase, sino usar <strong>tres TON que cuentan todos desde el inicio del ciclo</strong> con presets acumulados:</p>
    <ul>
      <li><strong>T1 = 10 s</strong> → marca el fin del <strong>verde</strong>.</li>
      <li><strong>T2 = 13 s</strong> (10 + 3) → marca el fin del <strong>amarillo</strong>.</li>
      <li><strong>T3 = 25 s</strong> (13 + 12) → marca el fin del <strong>rojo</strong> y reinicia el ciclo.</li>
    </ul>
    <p>Cada luz se enciende en la ventana entre el temporizador que la precede y el que la sigue. Así evitas la maraña de "reinicia este, arranca el otro" que suele dar errores.</p>

    <h2>Paso 3 — Ciclo cíclico con una marca</h2>
    <p>La marca <strong>M1</strong> (ciclo activo) se enclava con la marcha y habilita los tres temporizadores. Cuando <strong>T3</strong> termina, su contacto normalmente cerrado abre la rama que sostiene a M1 durante un ciclo de scan: los temporizadores, que dependen de M1, se ponen a cero; como la marcha sigue activa, M1 se vuelve a energizar y el ciclo reinicia automáticamente.</p>
    <pre class="not-prose bg-ink-900 text-ink-100 rounded-lg p-4 overflow-x-auto text-sm">{ladderCiclo}</pre>

    <h2>Paso 4 — Los tres temporizadores</h2>
    <p>Todos habilitados por M1, cada uno con su preset. En ZelioSoft son bloques de temporización tipo "retardo a la conexión" (equivalente al TON de la norma):</p>
    <pre class="not-prose bg-ink-900 text-ink-100 rounded-lg p-4 overflow-x-auto text-sm">{ladderTimers}</pre>

    <h2>Paso 5 — Las salidas por ventanas de tiempo</h2>
    <p>Aquí está la elegancia del método: cada salida es una simple combinación de "ya pasó el temporizador anterior Y todavía no pasó el siguiente".</p>
    <pre class="not-prose bg-ink-900 text-ink-100 rounded-lg p-4 overflow-x-auto text-sm">{ladderSalidas}</pre>
    <p>Verde entre 0 y 10 s (M1 activo y T1 aún sin cumplir), amarillo entre 10 y 13 s, rojo entre 13 y 25 s. Al llegar a 25 s, T3 reinicia todo y volvemos al verde.</p>

    <h2>Paso 6 — Simulación en ZelioSoft 2</h2>
    <p>Pulsa el botón de <strong>modo Simulación (S)</strong> en la barra de ZelioSoft 2. Fuerza la entrada <strong>I1</strong> a 1 (clic sobre la entrada) y observa cómo <strong>Q1 → Q2 → Q3</strong> se encienden en secuencia y el ciclo se repite. El modo S ejecuta el programa dentro del PC en tiempo real, sin necesidad del hardware. Cuando funcione, pasa al <strong>modo Monitorización (M)</strong> si tienes el Zelio conectado para verlo en el equipo real.</p>

    <h2>Cómo ampliarlo (para subir nota)</h2>
    <ul>
      <li><strong>Cruce de dos vías:</strong> añade tres salidas más (Q4-Q6) desfasadas medio ciclo; la vía B está en rojo mientras la A está en verde/amarillo.</li>
      <li><strong>Parpadeo nocturno:</strong> con un selector, sustituye el ciclo por un amarillo intermitente usando el reloj interno o un TON en modo oscilador.</li>
      <li><strong>Botón de peatón:</strong> una entrada extra que acorta el verde vehicular cuando se solicita el cruce.</li>
    </ul>

    <p class="not-prose"><a href="/guias/temporizador-ton-tof-ladder/" class="text-brand-600 hover:underline">Repasa los temporizadores TON/TOF</a> · <a href="/glosario/ladder/" class="text-brand-600 hover:underline">Qué es LADDER</a> · <a href="/guias/que-es-un-plc/" class="text-brand-600 hover:underline">Qué es un PLC</a></p>

    <AdSlot slot="3333333333" label="Publicidad" />

    <section class="not-prose mt-12 border-t border-ink-300/30 pt-8">
      <h2 class="text-2xl font-serif font-bold text-ink-900 mb-6">Preguntas frecuentes</h2>
      <div class="space-y-5">
        {faq.map((f) => (
          <div>
            <h3 class="font-semibold text-ink-900 mb-1">{f.q}</h3>
            <p class="text-ink-700">{f.a}</p>
          </div>
        ))}
      </div>
    </section>
  </article>
</Base>
