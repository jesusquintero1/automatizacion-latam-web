---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import ArticleCard from '../components/ArticleCard.astro';

const recientes = (await getCollection('noticias'))
  .sort((a, b) => new Date(b.data.fecha).valueOf() - new Date(a.data.fecha).valueOf())
  .slice(0, 4);
---
<Base
  title="Página no encontrada (404) — Automatización LatAm"
  description="La página que buscas no existe o fue movida. Mira las noticias más recientes de automatización industrial, IA y robótica."
  noIndex={true}
>
  <section class="mx-auto max-w-3xl px-4 md:px-8 py-16 text-center">
    <p class="text-brand-600 font-semibold uppercase tracking-wider text-sm mb-2">Error 404</p>
    <h1 class="text-4xl md:text-6xl font-serif font-bold text-ink-900 mb-4">
      No encontramos esta página
    </h1>
    <p class="text-ink-500 text-lg mb-8 max-w-xl mx-auto">
      Puede que el enlace esté roto, que la noticia haya sido reorganizada o que la URL tenga un
      error de tipeo. Aquí tienes accesos directos para volver al ruedo:
    </p>

    <div class="flex flex-wrap items-center justify-center gap-3 mb-12">
      <a href="/" class="px-5 py-3 rounded-md bg-brand-500 text-white font-semibold hover:bg-brand-600 transition">
        Ir al inicio
      </a>
      <a href="/categoria/inteligencia-artificial" class="px-5 py-3 rounded-md border border-ink-300/40 text-ink-700 hover:bg-ink-100 transition">
        Noticias de IA
      </a>
      <a href="/categoria/plc-y-control" class="px-5 py-3 rounded-md border border-ink-300/40 text-ink-700 hover:bg-ink-100 transition">
        PLC y Control
      </a>
      <a href="/categoria/robotica" class="px-5 py-3 rounded-md border border-ink-300/40 text-ink-700 hover:bg-ink-100 transition">
        Robótica
      </a>
    </div>
  </section>

  {recientes.length > 0 && (
    <section class="mx-auto max-w-[var(--container)] px-4 md:px-8 pb-16">
      <h2 class="text-2xl font-serif font-bold text-ink-900 mb-6 border-b border-ink-300/30 pb-3">
        Lo más reciente
      </h2>
      <div class="grid md:grid-cols-2 gap-8">
        {recientes.map((n) => <ArticleCard noticia={n} />)}
      </div>
    </section>
  )}
</Base>
